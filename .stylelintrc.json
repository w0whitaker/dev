{
	"extends": ["stylelint-config-standard"],
	"rules": {
		"declaration-block-no-redundant-longhand-properties": [
			true,
			{
				"ignoreShorthands": ["/flex/"]
			}
		],
		"rule-selector-property-disallowed-list": {
			"a": "/padding/",
			"p": "/padding/",
			"h1": "/padding/",
			"h2": "/padding/",
			"h3": "/padding/",
			"h4": "/padding/",
			"h5": "/padding/",
			"h6": "/padding/"
		},
		"custom-property-pattern": [
			"^([a-z][a-z0-9]*)([-,_]{1,2}[a-z0-9]+)*$",
			{
				"message": "Expected custom-property-pattern to single or double kebab-case."
			}
		]
	}
}
