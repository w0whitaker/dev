{
    "name": "williamwhitaker.dev",
    "version": "0.2.0",
    "description": "This is the development portfolio site for William Whitaker.",
    "main": ".eleventy.js",
    "scripts": {
        "clean": "rimraf _site",
        "dev:eleventy": "npx @11ty/eleventy --serve",
        "dev:postcss": "postcss src/assets/css/style.css -o src/_includes/critical-inline.css --watch --verbose",
        "start:debug": "DEBUG=Eleventy* npx @11ty/eleventy --serve",
        "start": "run-p dev:*",
        "build": "npx @11ty/eleventy",
        "test": "echo \"Error: no test specified\" && exit 1",
        "prepare": "husky install",
        "commitlint": "commitlint --edit",
        "commit": "commit",
        "minor": "npm version minor",
        "major": "npm version major",
        "patch": "npm version patch"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/w0whitaker/wwdev.git"
    },
    "keywords": [],
    "author": "",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/w0whitaker/wwdev/issues"
    },
    "homepage": "https://williamwhitaker.dev",
    "dependencies": {
        "@11ty/eleventy": "^2.0.1",
        "dotenv": "^16.0.0",
        "eleventy-plugin-footnotes": "^0.11.0",
        "markdown-it-anchor": "^8.6.3",
        "markdown-it-attrs": "^4.1.3",
        "postcss": "^8.4.29",
        "postcss-cli": "^10.1.0",
        "postcss-csso": "^6.0.1",
        "postcss-import": "^15.1.0",
        "postcss-import-ext-glob": "^2.1.1",
        "stylelint-config-standard-scss": "^10.0.0"
    },
    "devDependencies": {
        "@11ty/eleventy-img": "^3.1.0",
        "@11ty/eleventy-navigation": "^0.3.2",
        "@11ty/eleventy-plugin-syntaxhighlight": "^5.0.0",
        "@commitlint/cli": "^17.7.1",
        "@commitlint/config-conventional": "^17.7.0",
        "@commitlint/prompt-cli": "^17.7.1",
        "eslint": "^8.48.0",
        "eslint-config-prettier": "^9.0.0",
        "eslint-config-semistandard": "^17.0.0",
        "eslint-config-standard": "^17.1.0",
        "eslint-plugin-import": "^2.28.1",
        "eslint-plugin-n": "^15.7.0",
        "eslint-plugin-promise": "^6.1.1",
        "husky": "^8.0.0",
        "npm-run-all": "^4.1.5",
        "outdent": "^0.8.0",
        "prettier": "^3.0.2",
        "rimraf": "^5.0.1",
        "stylelint": "^15.10.3",
        "stylelint-config-standard": "^34.0.0"
    }
}
