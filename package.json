{
  "name": "wwdev",
  "version": "1.0.0",
  "description": "This is the portfolio site for William Whitaker.",
  "main": "index.js",
  "scripts": {
    "start": "npm-run-all clean -p dev:*",
    "clean": "rimraf _site",
    "dev:eleventy": "npx @11ty/eleventy --serve --incremental --watch",
		"dev:css": "tailwindcss -i ./src/assets/css/main.css -o ./_site/assets/css/main.css --watch --postcss",
    "start:debug": "DEBUG=Eleventy* npx @11ty/eleventy --serve",
    "build:eleventy": "npx @11ty/eleventy",
    "build": "npm-run-all build:sass build:eleventy",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/w0whitaker/wwdev.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/w0whitaker/wwdev/issues"
  },
  "homepage": "https://github.com/w0whitaker/wwdev#readme",
  "dependencies": {
    "@11ty/eleventy": "^2.0.1",
    "classnames": "^2.3.1",
    "dotenv": "^16.0.0",
    "eleventy-plugin-footnotes": "^0.11.0",
    "markdown-it-anchor": "^8.6.3",
    "markdown-it-attrs": "^4.1.3"
  },
  "devDependencies": {
    "@11ty/eleventy-img": "^3.1.0",
    "@11ty/eleventy-navigation": "^0.3.2",
    "@11ty/eleventy-plugin-syntaxhighlight": "^5.0.0",
    "autoprefixer": "^10.4.14",
    "eslint": "^8.14.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-import": "^2.26.0",
    "npm-run-all": "^4.1.5",
    "outdent": "^0.8.0",
    "postcss": "^8.4.23",
    "rimraf": "^5.0.1",
    "sass": "^1.50.1",
    "tailwindcss": "^3.3.2"
  }
}
