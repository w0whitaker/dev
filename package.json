{
    "name": "williamwhitaker.dev",
    "version": "0.4.1",
    "description": "This is the development portfolio site for William Whitaker.",
    "main": ".eleventy.js",
    "scripts": {
        "clean": "rimraf _site",
        "dev:eleventy": "npx @11ty/eleventy --serve",
        "dev:postcss": "npx postcss src/assets/css/bundle.css -o src/main.css --watch --verbose",
        "start": "run-s clean dev:eleventy",
        "start:debug": "DEBUG=Eleventy* npx @11ty/eleventy --serve",
        "build:style-dictionary": "style-dictionary build -c .style-dictionary.config.json",
        "build:postcss": "postcss src/assets/css/bundle.css -o src/main.css",
        "build:eleventy": "npx @11ty/eleventy",
        "build": "run-s clean build:*",
        "test": "echo \"Error: no test specified\" && exit 1",
        "minor": "npm version minor",
        "major": "npm version major",
        "patch": "npm version patch"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/w0whitaker/wwdev.git"
    },
    "keywords": [],
    "author": "",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/w0whitaker/wwdev/issues"
    },
    "homepage": "https://williamwhitaker.dev",
    "dependencies": {
        "@11ty/eleventy": "^2.0.1",
        "clean-css": "^5.3.2",
        "dotenv": "^16.0.0",
        "eleventy-plugin-footnotes": "^0.11.0",
        "markdown-it-anchor": "^8.6.3",
        "markdown-it-attrs": "^4.1.3",
        "postcss": "^8.4.29",
        "postcss-cli": "^10.1.0",
        "postcss-csso": "^6.0.1",
        "postcss-import": "^15.1.0",
        "postcss-import-ext-glob": "^2.1.1"
    },
    "devDependencies": {
        "@11ty/eleventy-img": "^3.1.0",
        "@11ty/eleventy-navigation": "^0.3.2",
        "critical": "^6.0.0",
        "eslint": "^8.48.0",
        "eslint-config-prettier": "^9.0.0",
        "eslint-plugin-import": "^2.28.1",
        "eslint-plugin-n": "^16.1.0",
        "eslint-plugin-promise": "^6.1.1",
        "npm-run-all": "^4.1.5",
        "outdent": "^0.8.0",
        "prettier": "^3.0.2",
        "rimraf": "^5.0.1",
        "style-dictionary": "^3.9.0",
        "stylelint": "^15.10.3",
        "stylelint-config-standard": "^34.0.0"
    }
