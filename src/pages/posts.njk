---js 
{
	title: 'posts',
	eleventyNavigation: {
		order: 2
	},
	pagination: {
		data: 'collections.posts',
		size: 2,
		alias: 'posts'
	},
	permalink: 'posts/{% if pagination.pageNumber > 0 %}page-{{ pagination.pageNumber + 1 }}/{% endif %}index.html'
	
}
---

<ul role="list" class="flow">
	{% for post in posts %}
		<li>
			<p>{{ post.data.title }}</p>
		</li>
	{% endfor %}
</ul>