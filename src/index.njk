</article>

<article>
  <h2>recent posts</h2>
{% snippet %}
{% if posts %}
{% for post in posts %}
- ### [{{ post.data.title }}]({{ post.url }})<br>
    <time datetime="{{ post.date | isoDate }}">{{ post.date | humanDate }}</time><br>
    <p>{{ post.data.excerpt }}</p>
{% endfor %}
{% else %}
No posts yet!
{% endif %}
{% endsnippet %}
</article>