<nav>
	{% if pageTitle === 'home' %}
    {% set activePage = "/" %}
	{% else %}
		{% set activePage = ["/", page.fileSlug, "/"] | join  %}
	{% endif %}
	<div class="layout:[ flex flex-col gap-2 ]">
		<span>other pages on this site:</span>

		<ul>
		{% for item in navigation.pages %}
			{% if  item.url != activePage %}
				<li class="typography:[ text-step-0 ]">
					<a href="{{ item.url }}" class=" aesthetic:[ underline underline-offset-4 decoration-sky-600 hover:decoration-wavy ]">"{{ item.text }}"</a>
				</li>
			{% endif %}
		{% endfor %}
		</ul>
	</div>
</nav>
