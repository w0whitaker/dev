<nav>
{% set activePage = page.url | url %}
	<div class="layout:[ flex flex-col gap-2 ]">
		<span>other pages on this site: </span>
		<ul>
		{% for page in collections.pages %}
			{% if page.url != activePage %}
				<li class="typography:[ text-step-0 ]">
					<a href="{{ page.url }}" class=" aesthetic:[ underline underline-offset-4 decoration-sky-600 hover:decoration-wavy ]">"{{ page.fileSlug }}."</a>
				</li>
			{% endif %}
		{% endfor %}
		</ul>
	</div>
</nav>
