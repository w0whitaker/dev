<ul role="list" class="switcher ">
  {%- for post in collections.posts | reverse -%}
    {%- if (post | isPublished) -%}
      <li>
        <div class="card">
          <h2>
            <a href="{{ post.url | url }}">{{ post.data.title }}</a>
          </h2>
          <div class="flow">
            <p class="subheading">
              {{ post.data.date | humanDate }}
            </p>
            <p>
              {{ post.data.teaser }}
            </p>
          </div>
        </div>
      </li>
    {%- endif -%}
  {%- endfor -%}
</ul>