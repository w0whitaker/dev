# https://github.com/11ty/11ty-website/blob/main/.editorconfig

root = true

[*]
indent_style = tab
indent_size = 2
end_of_line = lf
insert_final_newline = false
trim_trailing_whitespace = true
charset = utf-8

[*.js]
insert_final_newline = true
indent_style = tab

[*.json]
indent_style = tab

[*.css]
insert_final_newline = true
indent_style = tab